{
  "name": "react-native-video-pipeline-monorepo",
  "private": true,
  "version": "0.3.5",
  "description": "Offline video editing Nitro Module for React Native (iOS + Android). Monorepo root.",
  "license": "MIT",
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "yarn workspaces foreach --all --exclude react-native-video-pipeline-monorepo --parallel --topological run typecheck",
    "nitrogen": "yarn workspace react-native-video-pipeline run nitrogen",
    "lint": "yarn lint:biome && yarn lint:eslint",
    "lint:biome": "biome check .",
    "lint:eslint": "eslint .",
    "format": "biome format --write .",
    "test": "jest",
    "test:native": "bash scripts/test-native.sh",
    "smoke:ios": "bash scripts/smoke-ios.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@testing-library/react-native": "^12",
    "@types/jest": "^29",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^29",
    "ts-jest": "^29",
    "typescript": "^5.4.0"
  }
}
