{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "esModuleInterop": true,
    "baseUrl": ".",
    // Extend the RN preset's lib with es2022.error so `new Error(msg, {cause})`
    // in library sources typechecks — the library itself is ES2022, but the
    // RN tsconfig lib list omits that specific sub-lib.
    "lib": [
      "es2019",
      "es2020.bigint",
      "es2020.date",
      "es2020.number",
      "es2020.promise",
      "es2020.string",
      "es2020.symbol.wellknown",
      "es2021.promise",
      "es2021.string",
      "es2021.weakref",
      "es2022.array",
      "es2022.error",
      "es2022.object",
      "es2022.string"
    ],
    "paths": {
      "react-native-video-pipeline": ["../../packages/react-native-video-pipeline/src/index"],
      "react-native-video-pipeline-skia": [
        "../../packages/react-native-video-pipeline-skia/src/index"
      ]
    }
  },
  "include": ["App.tsx", "index.js", "metro.config.js", "babel.config.js"]
}
